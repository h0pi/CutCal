DB_SA_PASSWORD=YOUR_SA_PASSWORD

# Docker (docker-compose up) — SQL Server container, SQL auth:
# ConnectionStrings__DefaultConnection=Server=db,1433;Database=220240;User Id=sa;Password=YOUR_SA_PASSWORD;TrustServerCertificate=True;

# Local dev (dotnet run, no Docker) — SQL Server LocalDB, Windows auth:
ConnectionStrings__DefaultConnection=Server=(localdb)\MSSQLLocalDB;Database=220240;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true;
JwtToken__SecretKey=CutCalSuperSecretKey2024XYZ987654321ABCDEF
JwtToken__Issuer=CutCal
JwtToken__Audience=CutCalUsers
JwtToken__DurationInMinutes=60
RabbitMQ__Host=rabbitmq
RabbitMQ__Port=5672
RabbitMQ__Username=guest
RabbitMQ__Password=guest
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=cutcal@gmail.com
Smtp__Password=your-app-password
Smtp__UseSsl=true
PayPal__ClientId=YOUR_PAYPAL_SANDBOX_CLIENT_ID
PayPal__ClientSecret=YOUR_PAYPAL_SANDBOX_CLIENT_SECRET
PayPal__Mode=sandbox
